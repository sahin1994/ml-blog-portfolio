---
import { SITE, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-border">
  <div
    class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6 text-[13px] text-text-muted"
  >
    <span>© {year} {SITE.name}</span>
    <div class="flex items-center gap-3.5 text-base">
      {
        SOCIALS.map((s) => (
          <a href={s.href} aria-label={s.label} class="hover:text-text">
            <i class={`ti ${s.icon}`} aria-hidden="true" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
