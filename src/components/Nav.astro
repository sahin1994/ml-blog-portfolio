---
import { SITE, NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-3.5">
    <a href="/" class="flex items-center gap-2.5 font-serif text-[17px] font-medium">
      <span
        class="flex h-[22px] w-[22px] items-center justify-center rounded-md bg-accent text-[13px] text-white"
        >{SITE.name.charAt(0).toLowerCase()}</span
      >
      {SITE.name.toLowerCase()}
    </a>

    <div class="flex items-center gap-5 text-sm text-text-secondary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={['hover:text-text', isActive(item.href) && 'text-accent-text']}
          >
            {item.label}
          </a>
        ))
      }
      <button
        id="search-open"
        aria-label="Search"
        class="text-base text-text-muted hover:text-text"
      >
        <i class="ti ti-search" aria-hidden="true"></i>
      </button>
      <a
        href="https://github.com/sahin1994"
        aria-label="GitHub"
        class="text-base text-text-muted hover:text-text"
      >
        <i class="ti ti-brand-github" aria-hidden="true"></i>
      </a>
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="text-base text-text-muted hover:text-text"
      >
        <i class="ti ti-moon" aria-hidden="true"></i>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    const icon = btn?.querySelector('i');
    const sync = () => {
      const dark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (icon) icon.className = dark ? 'ti ti-sun' : 'ti ti-moon';
    };
    sync();
    btn?.addEventListener('click', () => {
      const next =
        document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      sync();
    });
  })();
</script>
