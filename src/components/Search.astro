---
// Site-wide full-text search powered by Pagefind. The index is generated at
// build time (`pagefind --site dist`), so search works in `npm run preview`
// and in production — not in `astro dev` (there's no built index yet).
---

<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-close></div>
  <div class="search-panel">
    <div class="search-head">
      <span class="text-sm text-text-muted">Search</span>
      <button data-close aria-label="Close search" class="text-text-muted hover:text-text">
        <i class="ti ti-x" aria-hidden="true"></i>
      </button>
    </div>
    <div id="pf-search"></div>
    <p id="pf-hint" class="search-hint">
      Search runs on the built site. Try <code>npm run build &amp;&amp; npm run preview</code>.
    </p>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 12vh;
  }
  .search-modal[hidden] { display: none; }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--text) 35%, transparent);
    backdrop-filter: blur(2px);
  }
  .search-panel {
    position: relative;
    width: min(600px, 92vw);
    max-height: 72vh;
    overflow-y: auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px 16px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
  }
  .search-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .search-hint {
    margin-top: 10px;
    font-size: 12px;
    color: var(--text-muted);
  }
  .search-hint code {
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--surface-1);
    padding: 1px 5px;
    border-radius: 4px;
  }
  #pf-search {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--surface-1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: var(--font-sans);
  }
</style>

<script is:inline>
  (function () {
    const modal = document.getElementById('search-modal');
    const hint = document.getElementById('pf-hint');
    if (!modal) return;
    let inited = false;

    function loadAsset(tag, attrs) {
      return new Promise((resolve, reject) => {
        const el = document.createElement(tag);
        Object.assign(el, attrs);
        el.onload = resolve;
        el.onerror = reject;
        document.head.appendChild(el);
      });
    }

    async function init() {
      if (inited) return;
      inited = true;
      try {
        await loadAsset('link', { rel: 'stylesheet', href: '/pagefind/pagefind-ui.css' });
        await loadAsset('script', { src: '/pagefind/pagefind-ui.js' });
        new window.PagefindUI({
          element: '#pf-search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
        if (hint) hint.remove();
      } catch {
        inited = false;
      }
    }

    function open() {
      modal.hidden = false;
      init();
      setTimeout(() => {
        const input = modal.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      }, 60);
    }
    function close() {
      modal.hidden = true;
    }

    window.openSearch = open;
    document.getElementById('search-open')?.addEventListener('click', open);
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
      if (e.key === '/' && modal.hidden && !/^(INPUT|TEXTAREA)$/.test(document.activeElement?.tagName)) {
        e.preventDefault();
        open();
      }
    });
  })();
</script>
