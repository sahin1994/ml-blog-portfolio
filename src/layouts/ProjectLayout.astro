---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, description, color, icon, tech, repo, demo, pubDate } = project.data;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-2xl px-6" data-pagefind-body>
    <a href="/projects" data-pagefind-ignore class="mt-8 inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-text">
      <i class="ti ti-arrow-left" aria-hidden="true"></i> projects
    </a>

    <header class="mt-6">
      <span
        class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl"
        style={`background: var(--${color}-bg)`}
      >
        <i class={`ti ${icon} text-2xl`} style={`color: var(--${color}-text)`} aria-hidden="true"></i>
      </span>
      <h1 class="font-serif text-[2rem] leading-tight font-medium">{title}</h1>
      <p class="mt-3 font-serif text-lg leading-relaxed text-text-secondary">{description}</p>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        {
          tech.map((t) => (
            <span
              class="rounded-full px-2.5 py-0.5 text-xs"
              style={`background: var(--${color}-bg); color: var(--${color}-text)`}
            >
              {t}
            </span>
          ))
        }
      </div>

      <div class="mt-5 flex gap-2.5">
        {
          repo && (
            <a
              href={repo}
              class="inline-flex items-center gap-1.5 rounded-lg border border-border px-3 py-1.5 text-sm hover:bg-surface-1"
            >
              <i class="ti ti-brand-github" aria-hidden="true" /> Code
            </a>
          )
        }
        {
          demo && (
            <a
              href={demo}
              class="inline-flex items-center gap-1.5 rounded-lg border border-border px-3 py-1.5 text-sm hover:bg-surface-1"
            >
              <i class="ti ti-external-link" aria-hidden="true" /> Live demo
            </a>
          )
        }
      </div>
      <p class="mt-5 text-[13px] text-text-muted">{formatDate(pubDate)}</p>
    </header>

    <div class="prose mt-8 border-t border-border pt-8">
      <slot />
    </div>
  </article>
</BaseLayout>
